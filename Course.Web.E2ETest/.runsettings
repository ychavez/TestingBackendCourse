<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <!-- Configuracion de Playwright para ejecutar las pruebas en modo visible (headed) -->
  <Playwright>
    <BrowserName>chromium</BrowserName>
    <LaunchOptions>
      <Headless>false</Headless>
      <SlowMo>500</SlowMo>
    </LaunchOptions>
  </Playwright>
  <NUnit>
    <NumberOfTestWorkers>1</NumberOfTestWorkers>
  </NUnit>
</RunSettings>
